# ==========================================
# TR3000 256M 基础配置 - 完整功能版
# ==========================================

# 目标平台：Mediatek Filogic
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cudy_tr3000-v1=y

# 镜像格式
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# 编译选项
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_USE_MKLIBS=y

# ==========================================
# 全中文界面设置
# ==========================================

# 默认语言为中文
CONFIG_LUCI_LANG_zh_Hans=y

# 禁用其他语言（减小体积）
# CONFIG_LUCI_LANG_en is not set
# CONFIG_LUCI_LANG_zh_Hant is not set
# CONFIG_LUCI_LANG_ja is not set
# CONFIG_LUCI_LANG_ko is not set
# CONFIG_LUCI_LANG_ru is not set
# CONFIG_LUCI_LANG_de is not set
# CONFIG_LUCI_LANG_fr is not set
# CONFIG_LUCI_LANG_it is not set
# CONFIG_LUCI_LANG_es is not set
# CONFIG_LUCI_LANG_pt is not set
# CONFIG_LUCI_LANG_vi is not set
# CONFIG_LUCI_LANG_ar is not set
# CONFIG_LUCI_LANG_he is not set
# CONFIG_LUCI_LANG_pl is not set
# CONFIG_LUCI_LANG_tr is not set
# CONFIG_LUCI_LANG_uk is not set
# CONFIG_LUCI_LANG_ro is not set

# 时区和本地化
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_kmod-nls-base=y
CONFIG_PACKAGE_kmod-nls-cp936=y           # 简体中文编码支持
CONFIG_PACKAGE_kmod-nls-utf8=y            # UTF-8 支持

# ==========================================
# 闭源大功率无线驱动（MT7981）- 官方闭源驱动
# ==========================================

# 完全禁用开源驱动
# CONFIG_PACKAGE_kmod-mt7915e is not set
# CONFIG_PACKAGE_kmod-mt7916-firmware is not set
# CONFIG_PACKAGE_kmod-mt7915-firmware is not set
# CONFIG_PACKAGE_kmod-mt7981-firmware is not set
# CONFIG_PACKAGE_kmod-mt76 is not set
# CONFIG_PACKAGE_kmod-mt76-core is not set
# CONFIG_PACKAGE_kmod-mt76-connac is not set

# MTK 闭源 WiFi 驱动（大功率版本）
CONFIG_PACKAGE_kmod-mt_wifi=y             # 闭源无线驱动核心
CONFIG_PACKAGE_mt_wifi=y                  # 闭源驱动工具
CONFIG_PACKAGE_luci-app-mtwifi-cfg=y      # 闭源驱动配置界面（中文）

# 闭源固件（大功率版本）
CONFIG_PACKAGE_mt7981-fw-20230808=y       # MT7981 固件
CONFIG_PACKAGE_mt7981-fw-20230421=y       # 备用固件版本

# 无线配置工具
CONFIG_PACKAGE_wifi-profile=y
CONFIG_PACKAGE_wireless-tools=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_iw=y

# 基础无线工具
CONFIG_PACKAGE_hostapd-common=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y
CONFIG_PACKAGE_kmod-cfg80211=y

# 大功率设置支持
CONFIG_PACKAGE_kmod-mtd-rw=y              # 允许修改无线功率参数

# ==========================================
# USB 支持（TR3000 有 USB 3.0 口）
# ==========================================
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_block-mount=y

# USB 文件系统支持
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y            # exFAT 支持（U盘常用）

# ==========================================
# USB 网络共享（手机共享网络）- 必需
# ==========================================
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y       # Android USB 共享
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y     # iPhone USB 共享
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=y  # 华为设备
CONFIG_PACKAGE_kmod-usb-net-ipheth=y      # iPhone 专用
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y   # 通用 CDC
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y    # 4G/5G 模块 MBIM 模式
CONFIG_PACKAGE_usb-modeswitch=y           # USB 模式切换

# ==========================================
# 5G 模块支持 - 新增完整支持
# ==========================================

# 基础 5G/4G 拨号支持
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y   # USB 转串口（5G模块通信）
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-usb-wdm=y             # USB 无线设备管理

# 5G 模块协议支持
CONFIG_PACKAGE_kmod-mii=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y    # QMI 协议（高通芯片5G模块）
CONFIG_PACKAGE_kmod-usb-net-sierrawireless=y  # Sierra Wireless 模块
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y    # MBIM 协议（Windows 5G模块常用）

# 5G 拨号工具
CONFIG_PACKAGE_quectel-CM-5G=y            # 移远5G模块拨号工具
CONFIG_PACKAGE_quectel-QMI-wwan=y         # 移远QMI驱动
CONFIG_PACKAGE_quectel-MBIM-wwan=y        # 移远MBIM驱动

# 通用 5G/4G 拨号
CONFIG_PACKAGE_comgt=y                    # 3G/4G 拨号工具
CONFIG_PACKAGE_comgt-ncm=y                # NCM 模式拨号
CONFIG_PACKAGE_uqmi=y                     # QMI 工具
CONFIG_PACKAGE_umbim=y                    # MBIM 工具
CONFIG_PACKAGE_modemmanager=y             # ModemManager（通用5G管理）

# 5G 模块 Luci 界面（中文）
CONFIG_PACKAGE_luci-app-modem=y           # 4G/5G 调制解调器管理（中文）
CONFIG_PACKAGE_luci-app-modemband=y       # 5G 频段锁定（中文）
CONFIG_PACKAGE_luci-app-sms-tool=y        # 短信工具（中文）

# 常见 5G 模块厂商支持
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=y   # 华为 5G
CONFIG_PACKAGE_kmod-usb-net-asix=y             # ASIX 网卡芯片
CONFIG_PACKAGE_kmod-usb-net-rtl8150=y          # Realtek USB 网卡
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y          # Realtek RTL8152/8153

# ==========================================
# 存储工具 - 文件管理必需
# ==========================================
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_dosfstools=y               # FAT 格式化
CONFIG_PACKAGE_ntfsprogs_ntfs-3g=y        # NTFS 修复
CONFIG_PACKAGE_hdparm=y                   # 硬盘参数设置
CONFIG_PACKAGE_smartmontools=y            # 硬盘健康检测

# ==========================================
# 文件管理 - 必需（全中文）
# ==========================================
CONFIG_PACKAGE_luci-app-filemanager=y     # Web 文件管理器（中文）
CONFIG_PACKAGE_luci-app-filetransfer=y    # 文件传输（中文）
CONFIG_PACKAGE_openssh-sftp-server=y      # SFTP 支持

# 磁盘管理（中文）
CONFIG_PACKAGE_luci-app-diskman=y         # 磁盘分区管理（中文）
CONFIG_PACKAGE_luci-app-hd-idle=y         # 硬盘休眠（中文）

# ==========================================
# 网络工具（基础）
# ==========================================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_ethtool=y                  # 网卡工具
CONFIG_PACKAGE_net-tools=y                # 传统网络工具（ifconfig等）
CONFIG_PACKAGE_iputils-ping=y             # ping 工具
CONFIG_PACKAGE_iputils-arping=y           # ARP 工具

# ==========================================
# 网络加速 - 必需（全中文界面）
# ==========================================

# 硬件 NAT 加速（MT7981 支持）
CONFIG_PACKAGE_kmod-hw_nat=y
CONFIG_PACKAGE_kmod-mtk-hnat=y

# SFE 加速（Shortcut Forwarding Engine）
CONFIG_PACKAGE_kmod-shortcut-fe=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y

# TCP 优化
CONFIG_PACKAGE_kmod-tcp-bbr=y             # BBR 拥塞控制

# SQM 智能队列（中文界面）
CONFIG_PACKAGE_luci-app-sqm=y             # 流量整形（中文）
CONFIG_PACKAGE_sqm-scripts=y

# TurboAcc 网络加速（中文）
CONFIG_PACKAGE_luci-app-turboacc=y        # 网络加速（含FastPath）
CONFIG_PACKAGE_kmod-fast-classifier=y
CONFIG_PACKAGE_kmod-ipt-offload=y

# ==========================================
# 科学上网 - OpenClash（全中文）
# ==========================================
CONFIG_PACKAGE_luci-app-openclash=y       # OpenClash（原生中文）

# OpenClash 依赖
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-tun=y

# DNS 工具（OpenClash 需要）
CONFIG_PACKAGE_dnsmasq-full=y             # 完整版 dnsmasq（中文界面）
# CONFIG_PACKAGE_dnsmasq is not set       # 禁用精简版

# ==========================================
# 广告过滤（中文界面，轻量级）
# ==========================================
CONFIG_PACKAGE_luci-app-dnsfilter=y       # DNS 广告过滤（中文）

# ==========================================
# 定时任务（中文）
# ==========================================
CONFIG_PACKAGE_luci-app-autoreboot=y      # 定时重启（中文）
CONFIG_PACKAGE_luci-app-watchcat=y        # 断网自动重启（中文）

# ==========================================
# DDNS 动态域名（中文）
# ==========================================
CONFIG_PACKAGE_luci-app-ddns=y            # DDNS（中文）
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_ddns-scripts-dnspod=y
CONFIG_PACKAGE_ddns-scripts-aliyun=y      # 阿里云
CONFIG_PACKAGE_ddns-scripts-cnkuai=y      # 花生壳

# ==========================================
# 网络共享（中文）
# ==========================================
CONFIG_PACKAGE_luci-app-samba4=y          # SMB 文件共享（中文）
CONFIG_PACKAGE_luci-app-minidlna=y        # DLNA 媒体服务器（中文）
CONFIG_PACKAGE_luci-app-usb-printer=y     # USB 打印服务器（中文）

# ==========================================
# 监控统计（中文）
# ==========================================
CONFIG_PACKAGE_luci-app-statistics=y      # 统计（中文）
CONFIG_PACKAGE_luci-app-nlbwmon=y         # 带宽监控（中文）

# 实时流量监控（中文）
CONFIG_PACKAGE_luci-app-wrtbwmon=y        # 实时流量（中文）

# ==========================================
# 系统工具（全中文）
# ==========================================
CONFIG_PACKAGE_luci-app-commands=y        # 自定义命令（中文）
CONFIG_PACKAGE_luci-app-ttyd=y            # Web 终端（中文）
CONFIG_PACKAGE_luci-app-uhttpd=y          # Web 服务器（中文）
CONFIG_PACKAGE_luci-app-firewall=y        # 防火墙（中文）
CONFIG_PACKAGE_luci-app-opkg=y            # 软件包管理（中文）
CONFIG_PACKAGE_luci-app-upnp=y            # UPnP（中文）

# 系统优化（中文）
CONFIG_PACKAGE_luci-app-cpufreq=y         # CPU 调频（中文）
CONFIG_PACKAGE_luci-app-ramfree=y         # 释放内存（中文）

# ==========================================
# 256M 内存优化：禁用不必要的大包
# ==========================================

# 禁用 IPv6（节省空间和内存）
# CONFIG_PACKAGE_ipv6helper is not set
# CONFIG_PACKAGE_kmod-ipv6 is not set
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set

# 禁用调试符号，减小体积
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_STRIP=y

# 禁用不常用的功能
CONFIG_PACKAGE_kmod-nf-conntrack-netlink=y  # 连接跟踪（加速需要）

# 禁用其他科学上网工具（只保留 OpenClash）
# CONFIG_PACKAGE_luci-app-passwall2 is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-v2ray-server is not set
# CONFIG_PACKAGE_luci-app-bypass is not set

# 禁用重型广告过滤
# CONFIG_PACKAGE_luci-app-adguardhome is not set
